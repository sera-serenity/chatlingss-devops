# MONGO
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_secret_key_here

# AWS (For Message Service / File Uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=cutechat-files

# SERVICE URLS
AUTH_SERVICE_URL=http://auth-service:5001
CHAT_SERVICE_URL=http://chat-service:5002
MESSAGE_SERVICE_URL=http://message-service:5003
GAME_SERVICE_URL=http://game-service:5004

# REDIS
REDIS_URL=redis://redis:6379
